PROJECT_NAME=market-surveillance
MARKET_TIMEZONE=Asia/Kolkata
MARKET_OPEN_IST=09:15
MARKET_CLOSE_IST=15:30
DEFAULT_TRADING_DATE=2026-03-16
DATA_ROOT=./data
FIXTURE_ROOT=./tests/fixtures
PYTHONUNBUFFERED=1

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_MARKET_TICKS_TOPIC=market_ticks
KAFKA_ANOMALY_DETECTIONS_TOPIC=anomaly_detections
KAFKA_DLQ_TOPIC=tick_dlq
KAFKA_CONSUMER_GROUP_STORAGE=storage-consumer
KAFKA_CONSUMER_GROUP_ANOMALY=anomaly-engine
KAFKA_CONSUMER_GROUP_CONTAGION=contagion-engine

CASSANDRA_HOSTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=market_surveillance
CASSANDRA_CONSISTENCY=ONE

REDIS_URL=redis://redis:6379/0

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=market_surveillance
POSTGRES_USER=market_user
POSTGRES_PASSWORD=market_pass
POSTGRES_DSN=postgresql://market_user:market_pass@postgres:5432/market_surveillance

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

ANOMALY_PRICE_Z_THRESHOLD=2.4
ANOMALY_VOLUME_Z_THRESHOLD=2.0
ANOMALY_COMPOSITE_THRESHOLD=2.2
ANOMALY_WARMUP_MINUTES=20
CONTAGION_WINDOW_MINUTES=5
ALERT_NOTIFY_MIN_SEVERITY=high
ALERT_WEBHOOK_TYPE=generic
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
ALERT_WEBHOOK_URL=
